<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Quiz - TRAPCITY RP Whitelist</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Orbitron:wght@400;700;900&display=swap" rel="stylesheet">
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: 'Inter', sans-serif; background: #000; color: #fff; }
        .font-orbitron { font-family: 'Orbitron', sans-serif; }
        .glass { background: rgba(255, 255, 255, 0.03); backdrop-filter: blur(20px); border: 1px solid rgba(255, 255, 255, 0.08); }
        .gradient-text { background: linear-gradient(135deg, #8b5cf6 0%, #a78bfa 50%, #fff 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
        .option-card { transition: all 0.3s ease; border: 2px solid rgba(255, 255, 255, 0.1); cursor: pointer; }
        .option-card:hover { border-color: #8b5cf6; background: rgba(139, 92, 246, 0.05); }
        .option-card.selected { border-color: #8b5cf6; background: rgba(139, 92, 246, 0.15); }
        .grid-number { transition: all 0.2s ease; width: 40px; height: 40px; display: flex; align-items: center; justify-content: center; border-radius: 8px; font-size: 14px; font-weight: 600; cursor: pointer; }
        .grid-number:hover { transform: scale(1.1); }
        .grid-number.answered { background: #10b981; color: white; }
        .grid-number.current { background: #8b5cf6; color: white; box-shadow: 0 0 15px rgba(139, 92, 246, 0.5); }
        .grid-number.pending { background: rgba(255, 255, 255, 0.1); color: #666; }
        .progress-fill { transition: width 0.5s ease; background: linear-gradient(90deg, #8b5cf6 0%, #a78bfa 100%); }
    </style>
</head>
<body class="bg-black min-h-screen">

    <div class="max-w-6xl mx-auto p-6">
        <!-- Header -->
        <div class="flex items-center justify-between mb-6">
            <div class="flex items-center gap-4">
                <a href="/dashboard" class="text-gray-400 hover:text-white flex items-center gap-2">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
                    Salir
                </a>
                <span class="text-sm text-gray-400">Formulario de Whitelist</span>
            </div>
            <div class="flex items-center gap-2 text-sm text-gray-400">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                <span id="timer"><%= Math.floor(elapsed / 60) %>:<%= String(elapsed % 60).padStart(2, '0') %></span>
            </div>
        </div>

        <!-- Progress -->
        <div class="mb-6">
            <div class="flex items-center justify-between text-sm mb-2">
                <span class="text-gray-400"><%= answered %> de <%= total %> respondidas</span>
                <span class="text-purple-400"><%= Math.round((answered / total) * 100) %>%</span>
            </div>
            <div class="h-2 bg-white/10 rounded-full overflow-hidden">
                <div class="progress-fill h-full" style="width: <%= (answered / total) * 100 %>%"></div>
            </div>
        </div>

        <!-- Quiz Content -->
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
            <!-- Question Area -->
            <div class="lg:col-span-2 glass rounded-2xl p-6 border border-white/10">
                <div class="mb-4">
                    <span class="inline-block px-3 py-1 bg-purple-500/20 text-purple-400 text-xs rounded-full mb-4">
                        <%= question.category %>
                    </span>
                    <h3 class="text-lg font-semibold mb-2">Pregunta <%= current %> de <%= total %></h3>
                    <p class="text-xl text-white"><%= question.question %></p>
                </div>
                
                <div class="space-y-3" id="options">
                    <% question.options.forEach((opt, idx) => { %>
                        <div class="option-card p-4 rounded-xl" onclick="selectOption('<%= idx %>')">
                            <div class="flex items-center gap-3">
                                <div class="w-8 h-8 rounded-full bg-white/10 flex items-center justify-center text-sm font-semibold option-letter">
                                    <%= String.fromCharCode(65 + idx) %>
                                </div>
                                <span class="text-white"><%= opt %></span>
                            </div>
                        </div>
                    <% }); %>
                </div>

                <div class="flex items-center justify-between mt-8 pt-6 border-t border-white/10">
                    <button onclick="prevQuestion()" 
                            class="px-6 py-3 bg-white/5 hover:bg-white/10 rounded-xl text-gray-400 hover:text-white transition flex items-center gap-2"
                            <%= current === 1 ? 'disabled style=\'opacity:0.5;cursor:not-allowed;\'' : '' %>>
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path></svg>
                        Anterior
                    </button>
                    <button onclick="nextQuestion()" class="px-6 py-3 bg-gradient-to-r from-purple-600 to-pink-600 hover:from-purple-500 hover:to-pink-500 rounded-xl text-white font-semibold flex items-center gap-2 transition">
                        Siguiente
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
                    </button>
                </div>
            </div>

            <!-- Navigation Grid -->
            <div class="glass rounded-2xl p-6 border border-white/10">
                <h4 class="font-semibold mb-4">Navegación</h4>
                <div class="grid grid-cols-5 gap-2 mb-4" id="navGrid">
                    <% for(let i = 1; i <= total; i++) { %>
                        <div class="grid-number <%= i === current ? 'current' : (i <= answered ? 'answered' : 'pending') %>" 
                             data-idx="<%= i - 1 %>">
                            <%= i %>
                        </div>
                    <% } %>
                </div>
                <div class="flex items-center gap-4 text-xs mb-4">
                    <div class="flex items-center gap-1"><div class="w-3 h-3 bg-purple-500 rounded"></div><span class="text-gray-400">Actual</span></div>
                    <div class="flex items-center gap-1"><div class="w-3 h-3 bg-green-500 rounded"></div><span class="text-gray-400">Respondida</span></div>
                    <div class="flex items-center gap-1"><div class="w-3 h-3 bg-white/10 rounded"></div><span class="text-gray-400">Pendiente</span></div>
                </div>
                <button onclick="submitQuiz()" id="submitBtn" class="w-full py-3 bg-green-600 hover:bg-green-500 rounded-xl font-semibold text-white transition opacity-50 cursor-not-allowed">
                    Enviar Formulario
                </button>
                <p class="text-xs text-gray-500 mt-2 text-center">Mínimo 35 respuestas para enviar</p>
            </div>
        </div>
    </div>

    <script>
        let currentQuestion = <%= current - 1 %>;
        const totalQuestions = <%= total %>;
        let selectedOption = null;
        let answers = {};

        // Cargar respuestas guardadas
        try {
            answers = JSON.parse(localStorage.getItem('whitelist_answers') || '{}');
        } catch(e) {
            answers = {};
        }

        // Restaurar selección actual
        if (answers[currentQuestion] !== undefined) {
            selectOption(answers[currentQuestion], false);
        }

        function selectOption(index, save = true) {
            selectedOption = index;
            document.querySelectorAll('.option-card').forEach((card, i) => {
                card.classList.toggle('selected', i === index);
            });
            
            if (save) {
                answers[currentQuestion] = index;
                localStorage.setItem('whitelist_answers', JSON.stringify(answers));
                
                // Guardar en servidor
                fetch('/whitelist/answer', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        questionIndex: currentQuestion,
                        answer: index
                    })
                });
                
                updateGrid();
                checkSubmit();
            }
        }

        function nextQuestion() {
            if (currentQuestion < totalQuestions - 1) {
                navigateTo(currentQuestion + 1);
            } else {
                submitQuiz();
            }
        }

        function prevQuestion() {
            if (currentQuestion > 0) {
                navigateTo(currentQuestion - 1);
            }
        }

        function goToQuestion(index) {
            navigateTo(index);
        }

        function navigateTo(index) {
            fetch('/whitelist/navigate', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ question: index })
            }).then(() => {
                location.reload();
            });
        }

        function updateGrid() {
            document.querySelectorAll('.grid-number').forEach((num, i) => {
                num.classList.remove('current', 'answered', 'pending');
                if (i === currentQuestion) {
                    num.classList.add('current');
                } else if (answers[i] !== undefined) {
                    num.classList.add('answered');
                } else {
                    num.classList.add('pending');
                }
            });
        }

        function checkSubmit() {
            const answeredCount = Object.keys(answers).length;
            const btn = document.getElementById('submitBtn');
            if (answeredCount >= 35) {
                btn.classList.remove('opacity-50', 'cursor-not-allowed');
                btn.textContent = 'Enviar Formulario';
            }
        }

        function submitQuiz() {
            const answeredCount = Object.keys(answers).length;
            if (answeredCount < 35) {
                alert('Debes responder al menos 35 preguntas');
                return;
            }
            
            if (confirm(`¿Estás seguro de enviar? Has respondido ${answeredCount} de ${totalQuestions} preguntas.`)) {
                fetch('/whitelist/submit', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' }
                })
                .then(r => r.json())
                .then(data => {
                    localStorage.removeItem('whitelist_answers');
                    window.location.href = data.redirect;
                });
            }
        }

        // Timer
        let elapsed = <%= elapsed %>;
        setInterval(() => {
            elapsed++;
            const mins = Math.floor(elapsed / 60);
            const secs = elapsed % 60;
            document.getElementById('timer').textContent = `${mins}:${secs.toString().padStart(2, '0')}`;
        }, 1000);

        checkSubmit();
    </script>

</body>
</html>
